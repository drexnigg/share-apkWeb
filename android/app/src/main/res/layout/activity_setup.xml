<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@string/app_name"
            android:layout_marginTop="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_subtitle"
            android:textColor="#CBD5E1"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4sp"
            android:layout_marginTop="10dp"
            android:paddingHorizontal="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_url_label"
                    android:textColor="#0F172A"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />

                <EditText
                    android:id="@+id/url_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/setup_url_hint"
                    android:inputType="textUri"
                    android:autofillHints="off"
                    android:importantForAutofill="no"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8"
                    android:layout_marginTop="8dp"
                    android:padding="12dp"
                    android:background="@drawable/input_bg" />

                <TextView
                    android:id="@+id/error_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#DC2626"
                    android:textSize="13sp"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"
                    tools:ignore="MissingDefaultResource"
                    xmlns:tools="http://schemas.android.com/tools" />

                <Button
                    android:id="@+id/save_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_save"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:backgroundTint="#2563EB"
                    android:layout_marginTop="20dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_help"
                    android:textColor="#6B7180"
                    android:textSize="12sp"
                    android:layout_marginTop="14dp"
                    android:lineSpacingExtra="3sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
